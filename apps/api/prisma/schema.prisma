// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  email String @unique
  password_hash String
  name String?
  role Role @default(USER)
  catalogs Catalog[] @relation("UserCatalogs")

  currentCatalog Catalog? @relation("UserCurrentCatalog", fields: [current_catalog_id], references: [id])
  current_catalog_id String? @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Catalog {
  id String @id @default(uuid())
  name String

  user User @relation("UserCatalogs", fields: [user_id], references: [id])
  user_id String

  currentFor User? @relation("UserCurrentCatalog")

  types Type[]
  categories Category[]
  items Item[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("catalogs")
}

model Type {
  id String @id @default(uuid())
  name String
  catalog Catalog @relation(fields: [catalog_id], references: [id])
  catalog_id String @unique
  items Item[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("types")
}

model Category {
  id String @id @default(uuid())
  name String
  catalog Catalog @relation(fields: [catalog_id], references: [id])
  catalog_id String @unique
  items Item[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("categories")
}

model Item {
  id String @id @default(uuid())
  name String
  catalog Catalog @relation(fields: [catalog_id], references: [id])
  catalog_id String @unique
  type Type @relation(fields: [type_id], references: [id])
  type_id String
  categories Category[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("items")
}

enum Role {
  USER
  ADMIN
}
